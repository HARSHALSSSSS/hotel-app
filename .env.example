# Copy to .env and fill in. Needed to run the app + server.

# PostgreSQL connection string (get a free one at https://neon.tech or https://supabase.com)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# API host for the app (no https://). Baked into APK at build time.
# - Emulator: localhost:5000
# - Physical phone + PC backend: YOUR_PC_IP:5000 (e.g. 192.168.0.103:5000)
#   Find PC IP: ipconfig (Windows) or ifconfig (Mac/Linux). Phone + PC must be on same WiFi.
# EXPO_PUBLIC_DOMAIN=localhost:5000

# Razorpay (required for card payments). Get keys from https://dashboard.razorpay.com/
# Test keys (rzp_test_xxx) for development; Live keys (rzp_live_xxx) for production.
# Card payment returns 503 if these are not set in .env
# RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
# RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
